---
---

<section id="home" class="relative min-h-screen flex items-center pt-24 overflow-hidden">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-primary/60 mix-blend-multiply z-10"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/50 to-transparent z-10"></div>
    <img 
      src="/images/hero_bg.png" 
      alt="Paisagismo noturno" 
      class="w-full h-full object-cover"
    />
  </div>

  <!-- Content -->
  <div class="relative z-20 max-w-7xl mx-auto px-6 lg:px-12 w-full">
    <div class="max-w-3xl">
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-serif text-light leading-[1.1] mb-8">
        PROJETAMOS <br/>
        <span class="text-light/90">NATUREZA.</span><br/>
        CULTIVAMOS <br/>
        <span class="text-light/90">HARMONIA.</span>
      </h1>
      
      <p class="text-lg text-light/80 mb-12 max-w-xl font-light leading-relaxed">
        Projetos paisagísticos exclusivos que conectam pessoas à natureza e transformam espaços em experiências.
      </p>
      
      <a 
        href="#portfolio" 
        class="inline-block border border-accent/50 text-accent hover:bg-accent hover:text-primary px-8 py-4 text-sm font-medium tracking-widest uppercase transition-all duration-300"
      >
        Conheça nossos projetos
      </a>
    </div>
  </div>
</section>
