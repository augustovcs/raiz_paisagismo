---
const services = [
  {
    title: "PROJETOS PAISAGÍSTICOS",
    description: "Projetos autorais que valorizam o ambiente e a experiência de quem vive.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8 text-accent mx-auto mb-6"><path d="M12 22C12 22 17 17 17 11C17 7.68629 14.7614 5 12 5C9.23858 5 7 7.68629 7 11C7 17 12 22 12 22Z" /><path d="M12 11C13.1046 11 14 10.1046 14 9C14 7.89543 13.1046 7 12 7C10.8954 7 10 7.89543 10 9C10 10.1046 10.8954 11 12 11Z" /><path d="M12 5V2" /><path d="M15 4L12 5L9 4" /></svg>`
  },
  {
    title: "CONSULTORIA",
    description: "Análise técnica e orientação especializada para transformar ideias em soluções.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8 text-accent mx-auto mb-6"><path d="M9 21H15" /><path d="M12 21V17" /><path d="M17 17H7C5.89543 17 5 16.1046 5 15V7C5 5.89543 5.89543 5 7 5H17C18.1046 5 19 5.89543 19 7V15C19 16.1046 18.1046 17 17 17Z" /><path d="M12 11C13.1046 11 14 10.1046 14 9C14 7.89543 13.1046 7 12 7C10.8954 7 10 7.89543 10 9C10 10.1046 10.8954 11 12 11Z" /></svg>`
  },
  {
    title: "EXECUÇÃO",
    description: "Implantação com excelência, cuidado em cada detalhe e materiais de qualidade.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8 text-accent mx-auto mb-6"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" /></svg>`
  },
  {
    title: "MANUTENÇÃO",
    description: "Cuidados contínuos para manter a beleza, saúde e harmonia do seu jardim.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8 text-accent mx-auto mb-6"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /><path d="M12 8v4" /><path d="M12 16h.01" /></svg>`
  },
  {
    title: "PAISAGISMO DE INTERIORES",
    description: "Integração entre natureza e arquitetura para ambientes internos sofisticados.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8 text-accent mx-auto mb-6"><rect x="3" y="3" width="18" height="18" rx="2" ry="2" /><circle cx="8.5" cy="8.5" r="1.5" /><polyline points="21 15 16 10 5 21" /></svg>`
  }
];
---

<section id="servicos" class="bg-secondary text-light py-24 relative">
  <!-- Subtle background pattern/texture overlay could go here -->
  
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="text-center mb-20">
      <h3 class="text-xs font-medium tracking-[0.2em] text-accent/80 uppercase mb-4">Serviços</h3>
      <h2 class="text-3xl md:text-4xl font-serif">
        SOLUÇÕES COMPLETAS <br/>
        <span class="text-light/80">PARA ESPAÇOS EXTRAORDINÁRIOS.</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-12 lg:gap-8">
      {services.map((service, index) => (
        <div class="text-center group">
          <div class="transition-transform duration-500 group-hover:-translate-y-2">
            <Fragment set:html={service.icon} />
          </div>
          
          <!-- Divider Line -->
          <div class="w-px h-12 bg-accent/20 mx-auto my-6 hidden lg:block"></div>
          <div class="w-12 h-px bg-accent/20 mx-auto my-6 lg:hidden"></div>
          
          <h4 class="text-sm font-medium tracking-widest text-accent mb-4 uppercase">
            {service.title}
          </h4>
          <p class="text-sm text-light/70 leading-relaxed max-w-xs mx-auto">
            {service.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
