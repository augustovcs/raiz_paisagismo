---
---

<section id="orcamento" class="bg-secondary relative overflow-hidden text-light">
  <!-- Abstract Leaf Graphic -->
  <div class="absolute right-0 bottom-0 opacity-10 pointer-events-none w-1/2 h-full flex justify-end items-end">
    <svg width="400" height="400" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-light">
      <path d="M100 200C100 200 0 150 0 100C0 50 50 0 100 0C150 0 200 50 200 100C200 150 100 200 100 200Z" fill="currentColor"/>
    </svg>
  </div>

  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-24 flex flex-col md:flex-row items-center justify-between relative z-10">
    <div class="w-full md:w-1/2 mb-12 md:mb-0">
      <h2 class="text-3xl md:text-5xl font-serif mb-6 leading-tight">
        VAMOS TRANSFORMAR <br/>
        SEU ESPAÇO?
      </h2>
      <p class="text-light/80 mb-8 max-w-md font-medium leading-relaxed">
        Fale com a nossa equipe e solicite um orçamento personalizado para o seu projeto.
      </p>
      
      <a 
        href="mailto:contato@raizapaisagismo.com.br" 
        class="inline-block border border-accent text-accent hover:bg-accent hover:text-primary px-8 py-4 text-xs font-medium tracking-widest uppercase transition-all duration-300"
      >
        Solicitar Orçamento <span class="ml-2">→</span>
      </a>
    </div>

    <!-- Big Logo -->
    <div class="w-full md:w-1/2 flex justify-end items-center opacity-80">
      <div class="text-right">
        <svg class="w-24 h-24 text-accent mb-4 ml-auto" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
          <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 1 8.3C11.6 9 7.1 14 11 20c.6-1.2 1.6-2.5 3.2-3.2"/>
        </svg>
        <div class="font-serif text-5xl tracking-widest text-accent uppercase mb-2">Raiza</div>
        <div class="text-[0.6rem] tracking-[0.3em] text-light/70 uppercase">Projetos Paisagísticos</div>
      </div>
    </div>
  </div>
</section>
