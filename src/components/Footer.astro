---
---

<footer id="contato" class="bg-[#dcd6ca] text-primary py-12 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-12 flex flex-col md:flex-row justify-between items-center md:items-start gap-8 relative z-10">
    
    <!-- Social -->
    <div class="flex items-center space-x-6 text-sm font-medium tracking-widest uppercase">
      <span>Siga-nos</span>
      <a href="#" class="hover:text-accent transition-colors">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
        </svg>
      </a>
      <a href="#" class="hover:text-accent transition-colors">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm1 14.5a3 3 0 0 1-3 3v-2.3a8.6 8.6 0 0 1 1-2.8l2.2-4.2a1 1 0 0 1 1.8.8l-2 3.8a2.6 2.6 0 0 0-.2 1.3 1.1 1.1 0 0 0 1.2 1 1.6 1.6 0 0 0 1.7-1.8 3.5 3.5 0 0 0-3.6-3.4 4 4 0 0 0-4 4 3 3 0 0 0 .5 1.8l-1.6 1.6a5 5 0 0 1-1-3.4 6 6 0 0 1 6-6 5.5 5.5 0 0 1 5.7 5.5 3.6 3.6 0 0 1-3.8 3.6z"></path>
        </svg>
      </a>
    </div>

    <!-- Contact -->
    <div class="text-center md:text-left">
      <h5 class="text-xs font-semibold tracking-widest text-primary/60 uppercase mb-4">Contato</h5>
      <p class="text-sm font-medium mb-1">(11) 99999-9999</p>
      <a href="mailto:contato@raizapaisagismo.com.br" class="text-sm font-medium hover:text-accent transition-colors">
        contato@raizapaisagismo.com.br
      </a>
    </div>

    <!-- Location -->
    <div class="text-center md:text-right">
      <h5 class="text-xs font-semibold tracking-widest text-primary/60 uppercase mb-4">Localização</h5>
      <p class="text-sm font-medium">São Paulo - SP</p>
    </div>
  </div>

  <!-- Decorative Leaf Graphic Bottom Right -->
  <div class="absolute -bottom-10 -right-10 opacity-20 pointer-events-none text-primary">
    <svg width="200" height="200" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="1">
      <path d="M50,100 C50,75 16,60 16,35 C16,20 33,10 50,5 C66,10 83,20 83,35 C83,60 50,75 50,100 Z" />
    </svg>
  </div>
</footer>
