---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "RAIZA - Projetos Paisagísticos que conectam pessoas à natureza." } = Astro.props;
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body class="bg-primary text-light font-sans antialiased overflow-x-hidden selection:bg-accent selection:text-primary">
    <slot />
  </body>
</html>
